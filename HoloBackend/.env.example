# Local development defaults.
PORT=8787
HOLO_ENFORCE_APP_ATTEST=false

# Local route selection. Keep provider as mock until at least one real API key is ready.
HOLO_CHAT_PROVIDER=mock
HOLO_CHAT_MODEL=holo-mock
HOLO_CHAT_TEMPERATURE=0.2
HOLO_CHAT_MAX_TOKENS=1024

HOLO_INTENT_PROVIDER=mock
HOLO_INTENT_MODEL=holo-mock
HOLO_INTENT_TEMPERATURE=0
HOLO_INTENT_MAX_TOKENS=512

HOLO_INSIGHT_PROVIDER=mock
HOLO_INSIGHT_MODEL=holo-mock
HOLO_INSIGHT_TEMPERATURE=0.3
HOLO_INSIGHT_MAX_TOKENS=2048

# Device-level limits for local testing.
HOLO_CHAT_REQUESTS_PER_MINUTE=20
HOLO_CHAT_REQUESTS_PER_DAY=50
HOLO_ASR_REQUESTS_PER_MINUTE=10
HOLO_ASR_REQUESTS_PER_DAY=20
HOLO_ASR_MAX_BYTES=10485760
HOLO_ASR_PROVIDER=mock

# Admin console. Leave password and token empty to disable admin endpoints.
HOLO_ADMIN_TOKEN=
HOLO_ADMIN_USERNAME=admin
HOLO_ADMIN_PASSWORD=
HOLO_ADMIN_SESSION_SECRET=
HOLO_ADMIN_LOG_MAX_ENTRIES=200
HOLO_ADMIN_LOG_DETAIL_MAX_CHARS=20000

# Real providers. Do not commit real values.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=

QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=

MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_API_KEY=

ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_API_KEY=

DASHSCOPE_API_KEY=
DASHSCOPE_ASR_WEBSOCKET_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
DASHSCOPE_ASR_MODEL=qwen3-asr-flash-realtime
DASHSCOPE_ASR_LANGUAGE=zh
DASHSCOPE_ASR_SAMPLE_RATE=16000

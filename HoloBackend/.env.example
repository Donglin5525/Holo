# Local development defaults.
PORT=8787
HOLO_ENFORCE_APP_ATTEST=false
HOLO_APP_ATTEST_TEAM_ID=
HOLO_APP_ATTEST_BUNDLE_ID=com.tangyuxuan.holo-app
HOLO_APP_ATTEST_ENVIRONMENT=development
# PEM 格式 Apple App Attest 可信根证书；生产强制校验时必填。
HOLO_APP_ATTEST_ROOT_CERTIFICATE_PATH=
HOLO_APP_ATTEST_CHALLENGE_TTL_SECONDS=300

# Sign in with Apple and owner-only diagnostics. Do not commit real subjects or secrets.
HOLO_APPLE_CLIENT_IDS=com.holo.Holo
HOLO_INTERNAL_DIAGNOSTICS_APPLE_SUBS=
HOLO_SESSION_SECRET=
HOLO_SESSION_TTL_SECONDS=3600
HOLO_SESSION_ISSUER=holo-ai-gateway
HOLO_SESSION_AUDIENCE=holo-ios

# Local route selection. Keep provider as mock until at least one real API key is ready.
HOLO_CHAT_PROVIDER=mock
HOLO_CHAT_MODEL=holo-mock
HOLO_CHAT_TEMPERATURE=0.2
HOLO_CHAT_MAX_TOKENS=1024
HOLO_CHAT_MAX_BODY_BYTES=262144
HOLO_CHAT_MAX_MESSAGES=100
HOLO_CHAT_MAX_MESSAGE_CHARS=65536
HOLO_CHAT_MAX_TOTAL_CHARS=204800
HOLO_DEVICE_ID_MAX_CHARS=128

HOLO_INTENT_PROVIDER=mock
HOLO_INTENT_MODEL=holo-mock
HOLO_INTENT_TEMPERATURE=0
HOLO_INTENT_MAX_TOKENS=4096

HOLO_INSIGHT_PROVIDER=mock
HOLO_INSIGHT_MODEL=holo-mock
HOLO_INSIGHT_TEMPERATURE=0.3
HOLO_INSIGHT_MAX_TOKENS=2048

# Device-level limits for local testing.
HOLO_CHAT_REQUESTS_PER_MINUTE=20
HOLO_CHAT_REQUESTS_PER_DAY=50
HOLO_ASR_REQUESTS_PER_MINUTE=10
HOLO_ASR_REQUESTS_PER_DAY=20
HOLO_ASR_MAX_BYTES=10485760
HOLO_ASR_ALLOWED_MIME_TYPES=audio/wav,audio/x-wav,audio/m4a,audio/mp4,audio/mpeg,audio/aac,audio/webm,audio/ogg,application/octet-stream
HOLO_ASR_PROVIDER=mock

# Admin console. Leave password and token empty to disable admin endpoints.
HOLO_ADMIN_TOKEN=
HOLO_ADMIN_USERNAME=admin
HOLO_ADMIN_PASSWORD=
HOLO_ADMIN_SESSION_SECRET=
HOLO_ADMIN_LOG_MAX_ENTRIES=200
HOLO_ADMIN_LOG_DETAIL_MAX_CHARS=20000
HOLO_ADMIN_LOGIN_MAX_ATTEMPTS=5
HOLO_ADMIN_LOGIN_WINDOW_SECONDS=900

# Real providers. Do not commit real values.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=

QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=

MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_API_KEY=

ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_API_KEY=

DASHSCOPE_API_KEY=
DASHSCOPE_ASR_WEBSOCKET_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
DASHSCOPE_ASR_MODEL=qwen3-asr-flash-realtime
DASHSCOPE_ASR_LANGUAGE=zh
DASHSCOPE_ASR_SAMPLE_RATE=16000

# SQLite database path. Defaults to /data/holo-backend.db in Docker.
HOLO_DB_PATH=/data/holo-backend.db

# Log content capture (disabled by default for privacy).
HOLO_LOG_CAPTURE_CONTENT=false
HOLO_LOG_RETENTION_DAYS=7
